pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Sriwastav07/git-job'
            }
        }

        stage('Build Website') {
            steps {
                sh 'npm install'
                sh 'npm run build'
            }
        }

        stage('Deploy Website') {
            steps {
                sh 'echo Deploying website...'
            }
        }
    }
}